<% include ../partials/header %>

<div class="row">
  <div class="col-lg-12">
    <h2><i class="fas fa-basketball-ball"></i> Team Management</h2>
    <p class="text-muted"><%= year %> Tournament &mdash; <a href="/admin">&laquo; Back to Dashboard</a></p>
    <hr>
  </div>
</div>

<% if(!tournament) { %>
  <div class="row">
    <div class="col-lg-12">
      <div class="alert alert-info">
        No tournament has been created for <%= year %> yet.
        <a href="/tournaments/new">Create one</a> to manage teams.
      </div>
    </div>
  </div>
<% } else if(teams.length === 0) { %>
  <div class="row">
    <div class="col-lg-12">
      <div class="alert alert-info">
        No teams found in the <%= year %> tournament bracket.
      </div>
    </div>
  </div>
<% } else { %>

  <div class="row" style="margin-bottom: 15px;">
    <div class="col-lg-12">
      <p>
        <strong><%= teams.length %> teams</strong> in the bracket.
        Edit names and aliases below. Aliases are comma-separated &mdash; these override the static alias map for CBS name matching.
      </p>
    </div>
  </div>

  <%
    // Group teams by region
    var regions = {};
    teams.forEach(function(t) {
      if(!regions[t.region]) regions[t.region] = [];
      regions[t.region].push(t);
    });
    var regionNames = Object.keys(regions).sort();
  %>

  <% regionNames.forEach(function(region) { %>
    <div class="row">
      <div class="col-lg-12">
        <div class="panel panel-default">
          <div class="panel-heading">
            <h4 class="panel-title"><%= region %> Region (<%= regions[region].length %> teams)</h4>
          </div>
          <div class="panel-body" style="overflow-x: auto;">
            <table class="table table-striped table-condensed">
              <thead>
                <tr>
                  <th style="width: 50px;">Seed</th>
                  <th style="width: 200px;">Team Name</th>
                  <th>Aliases (comma-separated)</th>
                  <th style="width: 80px;"></th>
                </tr>
              </thead>
              <tbody>
                <% regions[region].forEach(function(team) { %>
                  <tr>
                    <form action="/admin/teams/<%= team._id %>" method="POST">
                      <td>
                        <strong><%= team.seed %></strong>
                      </td>
                      <td>
                        <input type="text" name="name" value="<%= team.name %>" class="form-control input-sm" required>
                      </td>
                      <td>
                        <input type="text" name="aliases" value="<%= team.aliases ? team.aliases.join(', ') : '' %>" class="form-control input-sm" placeholder="e.g. UConn, Huskies">
                      </td>
                      <td>
                        <button type="submit" class="btn btn-sm btn-primary">Save</button>
                      </td>
                    </form>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  <% }); %>

<% } %>

<% include ../partials/footer %>
