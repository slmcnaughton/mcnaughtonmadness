<% include ../partials/header %>

<%
  // Sort trophies by year descending (most recent first)
  var sortedTrophies = user.trophies.slice().sort(function(a, b) { return b.year - a.year; });

  // Stats calculations
  var totalTournaments = sortedTrophies.length;
  var wins = sortedTrophies.filter(function(t) { return t.userRank === 1; }).length;
  var bestFinish = totalTournaments > 0
    ? Math.min.apply(null, sortedTrophies.map(function(t) { return t.userRank; }))
    : 0;
  var top3Count = sortedTrophies.filter(function(t) { return t.userRank <= 3; }).length;
  var top10Count = sortedTrophies.filter(function(t) { return t.userRank <= 10; }).length;
  var top50Count = sortedTrophies.filter(function(t) {
    return t.userRank <= Math.ceil(t.totalPlayers / 2);
  }).length;

  // Ordinal suffix helper
  function ordinal(n) {
    var s = ["th", "st", "nd", "rd"];
    var v = n % 100;
    return n + (s[(v - 20) % 10] || s[v] || s[0]);
  }

  // Trophy tier helper — determines tier from rank, totalPlayers, and madeAllPicks
  function getTrophyTier(trophy) {
    if (trophy.userRank === 1) return 'gold';
    if (trophy.userRank === 2) return 'silver';
    if (trophy.userRank === 3) return 'bronze';
    if (trophy.userRank <= 10) return 'top10';
    if (trophy.userRank <= Math.ceil(trophy.totalPlayers / 2)) return 'top50';
    // Last place logic: distinguish pick-misser from true last
    if (trophy.userRank === trophy.totalPlayers && trophy.totalPlayers > 3) {
      if (trophy.madeAllPicks === false) return 'misser';
      return 'last';
    }
    // Second-to-last could also be a misser
    if (trophy.madeAllPicks === false) return 'misser';
    return 'participation';
  }
%>

<!-- ── Profile Header ── -->
<div class="profile-header">
    <h1 class="profile-name"><%= user.firstName %> <%= user.lastName %>
        <% if(isUser) { %>
            <a href="/users/<%= user.username %>/edit" class="btn btn-default btn-sm" style="margin-left: 10px; vertical-align: middle;">
                <i class="fas fa-pencil-alt"></i> Edit Profile
            </a>
        <% } %>
        <% if(isUser && currentUser && currentUser.isAdmin) { %>
            <a href="/admin" class="btn btn-warning btn-sm" style="margin-left: 6px; vertical-align: middle;">
                <i class="fas fa-cog"></i> Admin
            </a>
        <% } %>
    </h1>

    <% if(totalTournaments > 0) { %>
    <div class="profile-stats">
        <div class="profile-stat">
            <span class="profile-stat-value"><%= totalTournaments %></span>
            <span class="profile-stat-label">Tournament<%= totalTournaments !== 1 ? 's' : '' %></span>
        </div>
        <div class="profile-stat">
            <span class="profile-stat-value"><%= wins %></span>
            <span class="profile-stat-label">Win<%= wins !== 1 ? 's' : '' %></span>
        </div>
        <div class="profile-stat">
            <span class="profile-stat-value"><%= ordinal(bestFinish) %></span>
            <span class="profile-stat-label">Best Finish</span>
        </div>
        <div class="profile-stat">
            <span class="profile-stat-value"><%= top3Count %></span>
            <span class="profile-stat-label">Top 3</span>
        </div>
        <div class="profile-stat">
            <span class="profile-stat-value"><%= top10Count %></span>
            <span class="profile-stat-label">Top 10</span>
        </div>
        <div class="profile-stat">
            <span class="profile-stat-value"><%= top50Count %></span>
            <span class="profile-stat-label">Top 50%</span>
        </div>
    </div>
    <% } %>

    <!-- Group badges -->
    <div class="profile-groups">
        <% if(user.tournamentGroups.length === 0) { %>
            <% if (isUser) { %>
                <p class="text-muted">You haven't joined any groups yet. <a href="/tournamentGroups/">Join one now!</a></p>
            <% } else { %>
                <p class="text-muted"><%= user.firstName %> hasn't joined any groups yet.</p>
            <% } %>
        <% } else { %>
            <%
              var sortedGroups = user.tournamentGroups.slice().sort(function(a, b) { return b.year - a.year; });
            %>
            <% for (var i = 0; i < sortedGroups.length; i++) { %>
                <a href="/tournamentGroups/<%= sortedGroups[i].groupName %>" class="profile-group-badge">
                    <i class="fas fa-users"></i> <%= sortedGroups[i].groupName %>
                </a>
            <% } %>
        <% } %>
    </div>
</div>

<!-- ── Trophy Case ── -->
<div class="profile-trophies-section">
    <h3 class="profile-trophies-title"><i class="fas fa-trophy" style="color: #FFA705;"></i> Trophy Case</h3>

    <% if(sortedTrophies.length > 0) { %>
    <div class="profile-trophy-grid">
        <% sortedTrophies.forEach(function(trophy) { %>
            <%
                var tier = getTrophyTier(trophy);
                // Only podium trophies (gold/silver/bronze) get special card borders
                var cardClass = 'profile-trophy-card';
                if (tier === 'gold')          cardClass += ' trophy-gold';
                else if (tier === 'silver')   cardClass += ' trophy-silver';
                else if (tier === 'bronze')   cardClass += ' trophy-bronze';
            %>
            <a href="/tournamentStandings#year-<%= trophy.year %>" class="<%= cardClass %>" style="text-decoration: none; color: inherit; display: block;">
                <div class="profile-trophy-img-wrap">
                    <% if (tier === 'gold') { %>
                        <img src="/imgs/trophies/first-place-trophy.png" alt="1st Place Trophy">
                    <% } else if (tier === 'silver') { %>
                        <img src="/imgs/trophies/second-place-trophy.png" alt="2nd Place Trophy">
                    <% } else if (tier === 'bronze') { %>
                        <img src="/imgs/trophies/third-place-trophy.png" alt="3rd Place Trophy">
                    <% } else if (tier === 'top10') { %>
                        <img src="/imgs/trophies/top-ten-trophy.svg" alt="Top 10 Trophy">
                    <% } else if (tier === 'top50') { %>
                        <img src="/imgs/trophies/top-fifty-trophy.svg" alt="Top 50% Medal">
                    <% } else if (tier === 'last') { %>
                        <img src="/imgs/trophies/toilet-trophy.png" alt="Last Place Trophy">
                    <% } else if (tier === 'misser') { %>
                        <img src="/imgs/trophies/pick-misser-trophy.svg" alt="Pick Misser">
                    <% } else { %>
                        <img src="/imgs/trophies/participation-ribbon.png" alt="Participation Ribbon">
                    <% } %>
                </div>
                <div class="profile-trophy-info">
                    <span class="profile-trophy-year"><%= trophy.year %></span>
                    <span class="profile-trophy-rank">
                        <% if (tier === 'gold') { %>
                            <i class="fas fa-crown" style="color: #D4AF37;"></i> Champion
                        <% } else if (tier === 'silver') { %>
                            Runner-Up
                        <% } else if (tier === 'bronze') { %>
                            3rd Place
                        <% } else if (tier === 'top10') { %>
                            Top 10
                        <% } else if (tier === 'top50') { %>
                            Top 50%
                        <% } else if (tier === 'last') { %>
                            Last Place
                        <% } else if (tier === 'misser') { %>
                            Pick Misser
                        <% } else { %>
                            Participation
                        <% } %>
                    </span>
                    <span class="profile-trophy-score"><%= ordinal(trophy.userRank) %> of <%= trophy.totalPlayers %> &middot; <%= trophy.score.toFixed(3) %> pts</span>
                </div>
            </a>
        <% }) %>
    </div>
    <% } else { %>
    <p class="text-muted text-center" style="margin-top: 20px;">
        <% if (isUser) { %>
            No trophies yet. Complete a tournament to earn your first!
        <% } else { %>
            <%= user.firstName %> hasn't earned any trophies yet.
        <% } %>
    </p>
    <% } %>
</div>

<% include ../partials/footer %>